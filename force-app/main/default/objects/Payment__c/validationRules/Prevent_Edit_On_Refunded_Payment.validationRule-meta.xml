<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Prevent_Edit_On_Refunded_Payment</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
  Refunded__c = TRUE,
  ISCHANGED(Amount_Paid__c)
)</errorConditionFormula>
    <errorMessage>Refunded payments cannot be edited.</errorMessage>
</ValidationRule>
