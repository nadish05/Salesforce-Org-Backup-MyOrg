<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Completion_Status</fullName>
    <active>true</active>
    <errorConditionFormula>AND( ISPICKVAL( Completion_Status__c , &quot;Completed&quot;) , ISBLANK( Email__c ))</errorConditionFormula>
    <errorMessage>Email is required when participant status is Completed.</errorMessage>
</ValidationRule>
